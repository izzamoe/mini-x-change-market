# ─── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_SHUTDOWN_TIMEOUT=30s

# ─── Storage ──────────────────────────────────────────────────────────────────
# "memory" (default) or "postgres"
STORAGE_TYPE=memory
DATABASE_URL=postgres://miniexchange:miniexchange@localhost:5432/miniexchange?sslmode=disable

# ─── DB Worker ────────────────────────────────────────────────────────────────
DB_WORKER_ENABLED=false
DB_WORKER_BATCH_SIZE=100
DB_WORKER_FLUSH_INTERVAL=100ms
DB_WORKER_CHANNEL_SIZE=5000
DB_WORKER_RETRY_MAX=3
DB_WORKER_RETRY_BACKOFF=1s

# ─── NATS ─────────────────────────────────────────────────────────────────────
NATS_ENABLED=false
NATS_URL=nats://localhost:4222

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# ─── Auth ─────────────────────────────────────────────────────────────────────
AUTH_ENABLED=false
JWT_SECRET=change-me-in-production
JWT_EXPIRY=24h

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200

# ─── Price Simulator ──────────────────────────────────────────────────────────
SIMULATOR_ENABLED=true
SIMULATOR_INTERVAL_MIN=1s
SIMULATOR_INTERVAL_MAX=3s

# ─── Binance External Feed (optional, requires internet) ──────────────────────
BINANCE_FEED_ENABLED=false
BINANCE_WS_URL=wss://stream.binance.com:9443
BINANCE_STREAMS=btcusdt@miniTicker/ethusdt@miniTicker/bnbusdt@miniTicker/solusdt@miniTicker/adausdt@miniTicker
BINANCE_RECONNECT_MAX=30s

# ─── WebSocket ────────────────────────────────────────────────────────────────
WS_MAX_CONNECTIONS=1000
WS_MAX_CONNECTIONS_PER_IP=10
WS_MAX_SUBSCRIPTIONS_PER_CLIENT=20
WS_WRITE_TIMEOUT=10s
WS_PING_INTERVAL=54s
WS_PONG_TIMEOUT=60s
WS_MAX_MESSAGE_SIZE=4096
WS_SEND_BUFFER_SIZE=256

# ─── Horizontal Scaling / Partitioning ───────────────────────────────────────
# Enable consistent-hash stock partitioning for multi-instance deployments.
# Each instance only runs the matching engine for its own subset of stocks.
# Orders for non-owned stocks are forwarded via NATS queue groups.
# Requires NATS_ENABLED=true.
PARTITION_ENABLED=false
# Zero-based index of this instance (0 … PARTITION_TOTAL_INSTANCES-1).
PARTITION_INSTANCE_INDEX=0
# Total number of application instances in the cluster.
PARTITION_TOTAL_INSTANCES=1

# ─── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL: debug | info | warn | error
LOG_LEVEL=info
# LOG_FORMAT: json | text
LOG_FORMAT=json
